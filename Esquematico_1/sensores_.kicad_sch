				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "e60a62d1-15f8-4d8c-9e33-4ecc2e51e784")
	)
	(text_box "IMU:\n-VDD : 1.71V to 3.6V typycal 1.8V (SOURCE)\n-VDDIO:1.71V to 3.6V typycal 1.8V (IO SUPPLY)\nProtocole of Comunication -- > SPI up to 28 Mhz\n- AP_SDO (only SPI)\n- AP_AD0 (I3C, I2C)\n\n-Resv all no connected or gnd, except for Resv_7 that must be gnd \n\nOBS!!!!! ver AP_CS e INT2, INT1, también 3 wire SPI o 4 SPI \n\nC1 : X7R 10% 0.1uF VDD\nC2 : X7R 10% 2.2uF VDD\nC3 : X7R 10% 10nF VDDIO\n\n"
		(exclude_from_sim no)
		(at 134.62 17.78 0)
		(size 62.23 43.18)
		(margins 0.9525 0.9525 0.9525 0.9525)
